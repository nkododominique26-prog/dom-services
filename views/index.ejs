<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MR DOM'S | Boutique Digitale</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #0f172a; color: white; }
        .card:hover { transform: translateY(-5px); transition: 0.3s; }
    </style>
</head>
<body>

    <nav class="flex justify-between items-center p-6 bg-slate-900 border-b border-slate-800">
        <h1 class="text-2xl font-bold tracking-tighter italic">MR DOM'S</h1>
        <a href="#" class="bg-indigo-600 hover:bg-indigo-700 px-5 py-2 rounded-full text-sm font-medium transition">
            Connexion
        </a>
    </nav>

    <header class="py-12 text-center">
        <h2 class="text-4xl font-extrabold mb-2">Votre Boutique Digitale</h2>
        <p class="text-slate-400">Services Premium & Boost Social Media</p>
    </header>

    <main class="max-w-6xl mx-auto px-6 pb-20">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <% services.forEach(service => { %>
                <div class="card bg-slate-800 p-6 rounded-2xl border border-slate-700 shadow-xl">
                    <div class="text-4xl mb-4"><%= service.icon %></div>
                    <h3 class="text-xl font-bold mb-2"><%= service.name %></h3>
                    <p class="text-slate-400 text-sm mb-4"><%= service.desc %></p>
                    <div class="flex justify-between items-center">
                        <span class="text-indigo-400 font-bold"><%= service.price %></span>
                        <button class="bg-white text-black px-4 py-1.5 rounded-lg text-xs font-bold hover:bg-slate-200">
                            Acheter
                        </button>
                    </div>
                </div>
            <% }); %>
        </div>
    </main>

    <footer class="text-center py-10 border-t border-slate-800 text-slate-500 text-sm">
        &copy; 2026 MR DOM'S - Tous droits réservés.
    </footer>

</body>
</html>
