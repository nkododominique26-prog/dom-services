<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dom's service | Boutique</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background-color: #0b0e14; color: #ffffff; font-family: 'Urbanist', sans-serif; overflow-x: hidden; }
        .gold-card { background: linear-gradient(135deg, #ffb800 0%, #ff8a00 100%); color: #000; }
        .product-card { background-color: #1a1e26; border-radius: 24px; border: 1px solid #334155; }
        .btn-buy { background-color: #0f172a; color: white; width: 100%; padding: 10px; border-radius: 12px; font-weight: bold; }
        
        /* Sidebar Styles */
        #sidebar {
            transform: translateX(-100%);
            transition: 0.3s ease-in-out;
            background-color: #111827;
            border-right: 1px solid #1f2937;
        }
        #sidebar.open { transform: translateX(0); }
        .overlay { display: none; background: rgba(0,0,0,0.7); }
        .overlay.active { display: block; }
    </style>
</head>
<body class="pb-24">

    <div id="overlay" class="overlay fixed inset-0 z-40" onclick="toggleMenu()"></div>

    <aside id="sidebar" class="fixed left-0 top-0 h-full w-64 z-50 p-6 flex flex-col">
        <div class="flex justify-between items-center mb-10">
            <h2 class="text-xl font-bold">Menu</h2>
            <button onclick="toggleMenu()"><i class="fas fa-times text-xl"></i></button>
        </div>

        <div class="flex items-center gap-4 mb-8 p-4 bg-slate-800/40 rounded-2xl border border-slate-700">
            <div class="w-12 h-12 bg-yellow-500 rounded-full flex items-center justify-center text-black font-bold text-xl">D</div>
            <div>
                <p class="font-bold text-sm">Mr Dom's</p>
                <p class="text-[10px] text-yellow-500 font-bold">2,500 Coins</p>
            </div>
        </div>

        <nav class="space-y-6 flex-grow">
            <a href="/" class="flex items-center gap-4 text-yellow-500 font-bold"><i class="fas fa-home"></i> Boutique</a>
            <a href="/vendre" class="flex items-center gap-4 text-slate-400 hover:text-white"><i class="fas fa-plus-circle"></i> Vendre un service</a>
            <a href="#" class="flex items-center gap-4 text-slate-400"><i class="fas fa-history"></i> Mes achats</a>
            <a href="#" class="flex items-center gap-4 text-slate-400"><i class="fas fa-headset"></i> Support WhatsApp</a>
        </nav>

        <div class="mt-auto pt-6 border-t border-slate-800">
            <button class="text-red-500 font-bold flex items-center gap-4"><i class="fas fa-sign-out-alt"></i> Déconnexion</button>
        </div>
    </aside>

    <header class="p-6 flex justify-between items-center">
        <button onclick="toggleMenu()" class="text-xl text-slate-400"><i class="fas fa-bars"></i></button>
        <h1 class="text-lg font-bold tracking-tight">Dom's service ⚡</h1>
        <div class="flex items-center gap-2 bg-slate-800/50 px-3 py-1.5 rounded-full border border-slate-700">
            <span class="font-bold text-yellow-500 text-sm">2,500</span>
            <i class="fas fa-coins text-yellow-500 text-xs"></i>
        </div>
    </header>

    <main class="px-6">
        <div class="gold-card p-6 rounded-[30px] shadow-lg mb-8">
            <p class="text-[10px] font-bold uppercase opacity-80 mb-1 tracking-widest">SOLDE ACTUEL</p>
            <h2 class="text-4xl font-extrabold mb-4">2,500 <span class="text-2xl">Coins</span></h2>
            <button class="bg-white/20 backdrop-blur-md border border-white/30 px-6 py-2 rounded-xl text-sm font-bold flex items-center gap-2">
                <i class="fas fa-plus"></i> Recharge
            </button>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <% if (services.length > 0) { %>
                <% services.forEach(service => { %>
                    <div class="product-card p-6 flex flex-col items-center">
                        <div class="w-14 h-14 mb-4 flex items-center justify-center text-4xl"><%= service.icon %></div>
                        <h3 class="font-bold text-xs text-center mb-1 leading-tight"><%= service.name %></h3>
                        <p class="text-yellow-500 font-bold text-[11px] mb-4"><%= service.price %> Coins</p>
                        <button class="btn-buy text-[10px] uppercase">Acheter</button>
                    </div>
                <% }); %>
            <% } else { %>
                <p class="col-span-2 text-center text-slate-500 py-10">Aucun article disponible.</p>
            <% } %>
        </div>
    </main>

    <script>
        function toggleMenu() {
            document.getElementById('sidebar').classList.toggle('open');
            document.getElementById('overlay').classList.toggle('active');
        }
    </script>

</body>
</html>
