<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MR DOM'S | Dashboard</title>
    <link rel="stylesheet" href="/css/style.css"> <script src="https://kit.fontawesome.com/your-code.js" crossorigin="anonymous"></script>
</head>
<body>

    <div class="container">
        <nav class="sidebar">
            <div class="logo">
                <h2>MR DOM'S</h2>
            </div>
            <ul>
                <li class="<%= page === 'dashboard' ? 'active' : '' %>">
                    <a href="/"><i class="fas fa-home"></i> Dashboard</a>
                </li>
                <li><a href="#"><i class="fas fa-list"></i> Liste des Tarifs</a></li>
                <li><a href="#"><i class="fas fa-plus-circle"></i> Publier Article</a></li>
                <li><a href="/logout" class="logout"><i class="fas fa-sign-out-alt"></i> Déconnexion</a></li>
            </ul>
        </nav>

        <main class="main-content">
            <header>
                <div class="user-profile">
                    <div class="avatar">
                        <%= user.username.substring(0, 2).toUpperCase() %>
                    </div>
                    <span>Bienvenue, <%= user.username %></span>
                </div>
            </header>

            <section class="content-area">
                <div class="publish-box">
                    <h3>Publier un nouveau service</h3>
                    <form action="/publier-article" method="POST">
                        <input type="text" name="title" placeholder="Titre (ex: 1000 Abonnés TikTok)" required>
                        
                        <select name="category">
                            <option value="TikTok">TikTok</option>
                            <option value="Instagram">Instagram</option>
                            <option value="Facebook">Facebook</option>
                            <option value="IPTV">IPTV</option>
                            <option value="Autre">Autre</option>
                        </select>

                        <input type="number" name="price" placeholder="Prix en FCFA" required>
                        <textarea name="description" placeholder="Description du service..." required></textarea>
                        
                        <button type="submit" class="btn-publish">Mettre en ligne</button>
                    </form>
                </div>

                <hr>

                <div class="articles-grid">
                    <% if (articles && articles.length > 0) { %>
                        <% articles.forEach(article => { %>
                            <div class="card">
                                <div class="card-header">
                                    <span class="category-tag"><%= article.category %></span>
                                    <form action="/supprimer-article/<%= article._id %>" method="POST" onsubmit="return confirm('Supprimer ce service ?')">
                                        <button type="submit" class="delete-icon">×</button>
                                    </form>
                                </div>
                                <h4><%= article.title %></h4>
                                <p><%= article.description %></p>
                                <div class="card-footer">
                                    <span class="price"><%= article.price %> FCFA</span>
                                    <button class="btn-order">Commander</button>
                                </div>
                            </div>
                        <% }) %>
                    <% } else { %>
                        <div class="empty-state">
                            <p>Aucun service publié pour le moment.</p>
                        </div>
                    <% } %>
                </div>
            </section>
        </main>
    </div>

</body>
</html>
