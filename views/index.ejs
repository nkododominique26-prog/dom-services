<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MR DOM'S | Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background-color: #0b0e14; color: #e2e8f0; font-family: 'Inter', sans-serif; }
        .sidebar { background-color: #111827; border-right: 1px solid #1f2937; }
        .card { background: rgba(17, 24, 39, 0.8); border: 1px solid #374151; backdrop-filter: blur(10px); transition: 0.3s; }
        .card:hover { border-color: #6366f1; transform: translateY(-2px); }
        .btn-gradient { background: linear-gradient(90deg, #6366f1 0%, #a855f7 100%); }
        .badge-user { background: #6366f1; color: white; padding: 2px 8px; border-radius: 12px; font-size: 10px; text-transform: uppercase; }
    </style>
</head>
<body class="flex min-h-screen">

    <aside class="w-64 sidebar hidden lg:flex flex-col">
        <div class="p-6 flex items-center gap-3">
            <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center">
                <i class="fas fa-cloud text-white"></i>
            </div>
            <h1 class="text-xl font-bold tracking-tight">MR DOM'S</h1>
        </div>

        <div class="px-4 py-6">
            <div class="flex items-center gap-3 p-4 bg-slate-800/50 rounded-xl mb-8">
                <div class="w-10 h-10 bg-indigo-500 rounded-full flex items-center justify-center font-bold">DO</div>
                <div>
                    <p class="text-sm font-bold">Doms</p>
                    <span class="badge-user">Utilisateur</span>
                </div>
            </div>

            <nav class="space-y-1">
                <a href="#" class="flex items-center gap-3 p-3 text-slate-400 hover:bg-slate-800 rounded-lg transition">
                    <i class="fas fa-th-large w-5"></i> Tableau de bord
                </a>
                <a href="#" class="flex items-center gap-3 p-3 text-indigo-400 bg-indigo-500/10 rounded-lg">
                    <i class="fab fa-whatsapp w-5"></i> Catalogue Bots
                </a>
                <a href="#" class="flex items-center gap-3 p-3 text-slate-400 hover:bg-slate-800 rounded-lg transition">
                    <i class="fas fa-coins w-5"></i> Acheter des crédits
                </a>
                <a href="#" class="flex items-center gap-3 p-3 text-slate-400 hover:bg-slate-800 rounded-lg transition">
                    <i class="fas fa-headset w-5"></i> Support
                </a>
            </nav>
        </div>
    </aside>

    <main class="flex-1 flex flex-col">
        <header class="h-16 border-b border-slate-800 flex items-center justify-between px-8 bg-[#0b0e14]">
            <i class="fas fa-bars lg:hidden text-2xl"></i>
            <div class="flex items-center gap-4">
                <div class="text-right hidden sm:block">
                    <p class="text-xs text-slate-500 leading-none">Solde</p>
                    <p class="text-sm font-bold text-indigo-400">1 500 Coins</p>
                </div>
                <div class="w-8 h-8 bg-slate-800 rounded-full flex items-center justify-center">
                    <i class="fas fa-bell text-xs text-slate-400"></i>
                </div>
            </div>
        </header>

        <section class="p-8">
            <div class="text-center mb-10">
                <span class="btn-gradient px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest mb-4 inline-block">Boutique Digitale</span>
                <h2 class="text-3xl font-extrabold mt-2">Déployez vos services <span class="text-indigo-500">en 1 minute</span></h2>
                <p class="text-slate-500 mt-2">Choisissez un service, configurez et recevez instantanément.</p>
            </div>

            <div class="max-w-md mx-auto mb-10">
                <div class="relative">
                    <i class="fas fa-search absolute left-4 top-3.5 text-slate-500"></i>
                    <input type="text" placeholder="Rechercher un service..." class="w-full bg-slate-900 border border-slate-700 rounded-xl py-3 pl-12 pr-4 focus:border-indigo-500 outline-none transition">
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                <% services.forEach(service => { %>
                    <div class="card p-6 rounded-2xl relative overflow-hidden">
                        <div class="flex justify-between items-start mb-4">
                            <div class="w-12 h-12 bg-indigo-500/20 rounded-xl flex items-center justify-center text-2xl">
                                <%= service.icon %>
                            </div>
                            <button class="text-slate-500 hover:text-white"><i class="fas fa-share-alt"></i></button>
                        </div>
                        <h3 class="text-xl font-bold uppercase tracking-tight"><%= service.name %></h3>
                        <p class="text-slate-500 text-sm mt-2 mb-6 h-12 overflow-hidden"><%= service.desc %></p>
                        
                        <div class="flex items-center gap-2 mb-6">
                            <span class="bg-slate-800 text-[10px] px-2 py-1 rounded border border-slate-700 uppercase">Premium</span>
                            <span class="bg-slate-800 text-[10px] px-2 py-1 rounded border border-slate-700 uppercase">Auto</span>
                        </div>

                        <div class="flex justify-between items-center pt-4 border-t border-slate-800">
                            <div>
                                <p class="text-[10px] text-slate-500 uppercase">Prix</p>
                                <p class="font-bold text-orange-400">💰 <%= service.price %></p>
                            </div>
                            <button class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-bold transition">
                                Acheter
                            </button>
                        </div>
                    </div>
                <% }); %>
            </div>
        </section>
    </main>

</body>
</html>
