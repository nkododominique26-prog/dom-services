<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dom Services - Accueil</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .service-card:active { transform: scale(0.95); transition: 0.2s; }
    </style>
</head>
<body class="bg-gray-50 pb-24">

    <div class="bg-blue-600 p-6 rounded-b-[40px] shadow-lg mb-8">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-white text-xl font-bold italic">Dom Services</h1>
            <div class="bg-white/20 p-2 rounded-full text-white">
                <i class="fas fa-bell"></i>
            </div>
        </div>
        
        <div class="bg-white p-6 rounded-3xl shadow-sm flex justify-between items-center">
            <div>
                <p class="text-gray-400 text-xs font-bold uppercase tracking-wider">Mon Solde</p>
                <h2 class="text-3xl font-black text-gray-800"><%= user.solde %> <span class="text-sm text-blue-600">Coins</span></h2>
            </div>
            <a href="/recharge" class="bg-blue-600 text-white p-3 rounded-2xl shadow-lg shadow-blue-200">
                <i class="fas fa-plus"></i>
            </a>
        </div>
    </div>

    <div class="px-5">
        <h3 class="text-gray-800 font-bold mb-4 flex items-center">
            <i class="fas fa-star text-orange-400 mr-2"></i> Nos Services
        </h3>
        
        <div class="grid grid-cols-2 gap-4">
            <% produits.forEach(produit => { %>
                <div class="service-card bg-white p-4 rounded-3xl border border-gray-100 shadow-sm flex flex-col items-center text-center">
                    <div class="w-16 h-16 mb-3 flex items-center justify-center">
                        <img src="<%= produit.image %>" class="max-h-full rounded-xl">
                    </div>
                    <h4 class="font-bold text-sm text-gray-700 mb-1"><%= produit.nom %></h4>
                    <p class="text-blue-600 font-black text-sm mb-3"><%= produit.prix %> FCFA</p>
                    <button class="w-full bg-gray-100 text-gray-800 py-2 rounded-xl text-xs font-bold hover:bg-blue-600 hover:text-white transition">
                        Acheter
                    </button>
                </div>
            <% }) %>
        </div>
    </div>

    <div class="fixed bottom-0 w-full bg-white border-t border-gray-100 py-4 flex justify-around items-center px-6">
        <div class="flex flex-col items-center text-blue-600">
            <i class="fas fa-home text-xl"></i>
            <span class="text-[10px] mt-1 font-bold">Accueil</span>
        </div>
        <a href="/recharge" class="flex flex-col items-center text-gray-400">
            <i class="fas fa-wallet text-xl"></i>
            <span class="text-[10px] mt-1 font-bold">Recharge</span>
        </a>
        <a href="/profil" class="flex flex-col items-center text-gray-400">
            <i class="fas fa-user-circle text-xl"></i>
            <span class="text-[10px] mt-1 font-bold">Profil</span>
        </a>
    </div>

</body>
</html>
