<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Dom Services - Test</title>
    <style>
        body { background-color: #001f3f; color: white; font-family: sans-serif; text-align: center; padding-top: 50px; }
        .card { border: 1px solid white; padding: 20px; display: inline-block; border-radius: 10px; }
    </style>
</head>
<body>
    <h1>Bienvenue sur Dom Services</h1>
    <p>Utilisateur : <%= user.nom %></p>
    <p>Solde : <%= user.solde %> FCFA</p>

    <div class="card">
        <h3>Produits disponibles :</h3>
        <ul>
            <% produits.forEach(function(produit) { %>
                <li><%= produit.nom %> - <%= produit.prix %> FCFA</li>
            <% }); %>
        </ul>
    </div>
</body>
</html>
