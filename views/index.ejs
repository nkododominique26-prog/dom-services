<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KermStyle Dashboard - Mr Dom's</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-[#0f111a] text-white font-sans flex min-h-screen">

    <aside class="w-64 bg-[#161926] border-r border-white/5 flex flex-col hidden md:flex">
        <div class="p-6">
            <div class="flex items-center gap-3 mb-10">
                <div class="bg-purple-600 p-2 rounded-lg">
                    <i class="fas fa-cloud text-xl"></i>
                </div>
                <span class="text-xl font-bold tracking-tight">KermStyle</span>
            </div>

            <div class="flex items-center gap-3 p-3 bg-white/5 rounded-2xl mb-8">
                <div class="w-10 h-10 bg-purple-500 rounded-full flex items-center justify-center font-bold text-sm">
                    <%= user.username.substring(0, 2).toUpperCase() %>
                </div>
                <div class="overflow-hidden">
                    <p class="text-sm font-bold truncate"><%= user.username %></p>
                    <span class="text-[10px] bg-purple-600/30 text-purple-400 px-2 py-0.5 rounded-full">user</span>
                </div>
            </div>

            <nav class="space-y-2">
                <a href="/" class="flex items-center gap-3 p-3 rounded-xl transition <%= page === 'dashboard' ? 'bg-gradient-to-r from-purple-600/20 to-transparent border-l-4 border-purple-600 text-white' : 'text-gray-400 hover:bg-white/5' %>">
                    <i class="fas fa-chart-pie w-5"></i> Tableau de bord
                </a>
                <a href="/tarifs" class="flex items-center gap-3 p-3 rounded-xl text-gray-400 hover:bg-white/5 transition">
                    <i class="fas fa-tags w-5"></i> Tarifs
                </a>
                <a href="/buy-coins" class="flex items-center gap-3 p-3 rounded-xl text-gray-400 hover:bg-white/5 transition">
                    <i class="fas fa-coins w-5"></i> Acheter des coins
                </a>
                <a href="#" class="flex items-center gap-3 p-3 rounded-xl text-gray-400 hover:bg-white/5 transition">
                    <i class="fas fa-user w-5"></i> Profil
                </a>
                <a href="#" class="flex items-center gap-3 p-3 rounded-xl text-gray-400 hover:bg-white/5 transition">
                    <i class="fas fa-history w-5"></i> Transactions
                </a>
            </nav>
        </div>

        <div class="mt-auto p-6 border-t border-white/5">
            <a href="/logout" class="flex items-center gap-3 text-gray-500 hover:text-red-400 transition">
                <i class="fas fa-sign-out-alt"></i> Déconnexion
            </a>
        </div>
    </aside>

    <main class="flex-1 flex flex-col">
        <header class="md:hidden p-4 bg-[#161926] flex justify-between items-center border-b border-white/5">
            <span class="font-bold">KermStyle</span>
            <button class="text-2xl"><i class="fas fa-bars"></i></button>
        </header>

        <div class="p-6 md:p-10">
            <div class="flex justify-between items-center mb-10">
                <div>
                    <h2 class="text-2xl font-bold">Tableau de bord</h2>
                    <p class="text-gray-500 text-sm">Bienvenue, <%= user.username %></p>
                </div>
                <div class="flex gap-4">
                    <div class="bg-[#161926] px-4 py-2 rounded-xl border border-white/5 flex flex-col items-center">
                        <span class="text-purple-500 font-bold text-lg"><%= user.coins %></span>
                        <span class="text-[10px] text-gray-500 uppercase">Coins</span>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-[#161926] p-6 rounded-3xl border border-white/5 relative overflow-hidden group">
                    <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition">
                        <i class="fab fa-tiktok text-6xl"></i>
                    </div>
                    <h3 class="font-bold text-lg mb-2">Boost TikTok</h3>
                    <p class="text-gray-500 text-xs mb-6">Vues, Likes et Abonnés instantanés.</p>
                    <button class="w-full bg-white/5 hover:bg-purple-600 py-3 rounded-xl transition font-bold text-sm">Commander</button>
                </div>

                <div class="bg-[#161926] p-6 rounded-3xl border border-white/5 relative overflow-hidden group">
                    <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition">
                        <i class="fas fa-play text-6xl"></i>
                    </div>
                    <h3 class="font-bold text-lg mb-2">Netflix 4K</h3>
                    <p class="text-gray-500 text-xs mb-6">Comptes premium haute qualité.</p>
                    <button class="w-full bg-white/5 hover:bg-purple-600 py-3 rounded-xl transition font-bold text-sm">Commander</button>
                </div>
            </div>

            <div class="mt-12 p-8 bg-gradient-to-br from-[#1c2136] to-[#161926] rounded-[2rem] border border-white/5 flex flex-col md:flex-row items-center justify-between gap-6">
                <div>
                    <h3 class="text-xl font-bold mb-2">Besoin de Coins ?</h3>
                    <p class="text-gray-400 text-sm">Rechargez votre compte via Mobile Money au Cameroun.</p>
                </div>
                <a href="https://wa.me/2376XXXXXXXX" class="bg-green-600 hover:bg-green-700 px-8 py-4 rounded-2xl font-bold transition flex items-center gap-3">
                    <i class="fab fa-whatsapp text-xl"></i> Contact Admin
                </a>
            </div>
        </div>
    </main>

</body>
</html>
