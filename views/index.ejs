<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MR DOM'S - <%= page.toUpperCase() %></title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="dark-theme">

    <div class="app-container">
        <!-- BARRE LATÉRALE -->
        <aside class="sidebar">
            <div class="brand">
                <i class="fas fa-bolt"></i>
                <span>MR DOM'S</span>
            </div>

            <div class="user-card">
                <div class="avatar">DO</div>
                <div class="user-info">
                    <strong><%= user.username %></strong>
                    <span class="badge"><%= user.role || 'CLIENT' %></span>
                </div>
            </div>

            <nav class="menu">
                <a href="/" class="<%= page === 'dashboard' ? 'active' : '' %>">
                    <i class="fas fa-chart-pie"></i> Dashboard
                </a>
                <a href="/p/tarifs" class="<%= page === 'tarifs' ? 'active' : '' %>">
                    <i class="fas fa-tags"></i> Liste des Tarifs
                </a>
                <a href="/p/recharge" class="<%= page === 'recharge' ? 'active' : '' %>">
                    <i class="fas fa-plus-circle"></i> Acheter Coins
                </a>
                <a href="/p/publier" class="<%= page === 'publier' ? 'active' : '' %>">
                    <i class="fas fa-edit"></i> Publier Article
                </a>
                <a href="/p/approbation" class="<%= page === 'approbation' ? 'active' : '' %>">
                    <i class="fas fa-user-shield"></i> Admin Approbation
                </a>
            </nav>

            <a href="/logout" class="logout-btn">
                <i class="fas fa-power-off"></i> Déconnexion
            </a>
        </aside>

        <!-- CONTENU -->
        <main class="content">
            <% if (page === 'dashboard') { %>
                <h2>Dashboard</h2>
                <div class="stats-grid">
                    <!-- Tes cartes de statistiques ici -->
                </div>
            <% } else if (page === 'publier') { %>
                <div class="form-card">
                    <h3>Nouveau Service</h3>
                    <form action="/add-service" method="POST">
                        <input type="text" name="title" placeholder="Nom du service..." required>
                        <select name="category">
                            <option value="TikTok Boost">TikTok Boost</option>
                            <option value="Instagram">Instagram</option>
                            <option value="Facebook">Facebook</option>
                        </select>
                        <input type="number" name="price" placeholder="Prix (FCFA)" required>
                        <textarea name="description" placeholder="Détails du service..."></textarea>
                        <button type="submit" class="btn-publish">Publier</button>
                    </form>
                </div>
            <% } else if (page === 'tarifs') { %>
                <h2>Liste des Tarifs</h2>
                <!-- Boucle sur articles -->
            <% } %>
        </main>
    </div>

</body>
</html>
