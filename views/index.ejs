<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Mr Dom's</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-[#1a1625] text-white">

    <nav class="bg-[#241e35] p-4 flex justify-between items-center border-b border-white/5">
        <h1 class="text-xl font-bold text-purple-500">MR DOM'S</h1>
        <div class="flex items-center gap-4">
            <span class="bg-purple-600/20 text-purple-400 px-3 py-1 rounded-full text-sm font-bold">
                <%= user.coins %> FCFA
            </span>
            <a href="/logout" class="text-gray-400"><i class="fas fa-sign-out-alt"></i></a>
        </div>
    </nav>

    <div class="p-6 max-w-4xl mx-auto">
        <h2 class="text-lg font-semibold mb-6">Services Disponibles</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="bg-[#241e35] p-5 rounded-2xl border border-white/5 hover:border-purple-500 transition">
                <div class="flex justify-between mb-4">
                    <div class="bg-pink-500/20 p-3 rounded-xl text-pink-500"><i class="fab fa-tiktok text-2xl"></i></div>
                    <span class="text-green-500 font-bold">Dès 100 F</span>
                </div>
                <h3 class="font-bold">Boost TikTok/Insta</h3>
                <p class="text-gray-400 text-sm mb-4">Abonnés et vues rapides.</p>
                <button class="w-full bg-purple-600 py-3 rounded-xl font-bold">Commander</button>
            </div>

            <div class="bg-[#241e35] p-5 rounded-2xl border border-white/5 hover:border-purple-500 transition">
                <div class="flex justify-between mb-4">
                    <div class="bg-red-500/20 p-3 rounded-xl text-red-500"><i class="fas fa-tv text-2xl"></i></div>
                    <span class="text-green-500 font-bold">2500 F</span>
                </div>
                <h3 class="font-bold">Netflix / IPTV</h3>
                <p class="text-gray-400 text-sm mb-4">Comptes Premium 4K.</p>
                <button class="w-full bg-purple-600 py-3 rounded-xl font-bold">Commander</button>
            </div>
        </div>

        <div class="mt-8 bg-purple-900/20 p-6 rounded-3xl border border-purple-500/30 text-center">
            <p class="text-sm mb-4">Pour recharger votre solde Mobile Money :</p>
            <a href="https://wa.me/2376XXXXXXXX" class="bg-green-600 px-6 py-3 rounded-xl font-bold inline-block">
                <i class="fab fa-whatsapp mr-2"></i>Contact Admin
            </a>
        </div>
    </div>
</body>
</html>
