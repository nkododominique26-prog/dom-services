<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dom's service | Boutique</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background-color: #0b0e14; color: #ffffff; font-family: 'Urbanist', sans-serif; padding-bottom: 100px; }
        .gold-card { background: linear-gradient(135deg, #ffb800 0%, #ff8a00 100%); color: #000; }
        .product-card { background-color: #1a1e26; border-radius: 24px; transition: 0.3s; border: 1px solid #334155; }
        .btn-buy { background-color: #0f172a; color: white; width: 100%; padding: 10px; border-radius: 12px; font-weight: bold; }
        .nav-bottom { background-color: #111827; border-top: 1px solid #1f2937; }
        .category-pill { background-color: #1a1e26; border: 1px solid #334155; padding: 8px 20px; border-radius: 20px; font-size: 14px; white-space: nowrap; }
        .category-pill.active { background-color: #ffffff; color: #000; }
        .no-scrollbar::-webkit-scrollbar { display: none; }
    </style>
</head>
<body>

    <header class="p-6 flex justify-between items-center">
        <h1 class="text-xl font-bold tracking-tight">Dom's service <i class="fas fa-bolt text-yellow-400"></i></h1>
        <div class="flex items-center gap-2 bg-slate-800/50 px-3 py-1.5 rounded-full border border-slate-700">
            <span class="font-bold text-yellow-500">2,500</span>
            <i class="fas fa-coins text-yellow-500"></i>
        </div>
    </header>

    <main class="px-6">
        <div class="gold-card p-6 rounded-[30px] shadow-lg mb-8 relative overflow-hidden">
            <p class="text-xs font-bold uppercase opacity-80 mb-1">Solde Actuel</p>
            <h2 class="text-4xl font-extrabold mb-4">2,500 <span class="text-2xl">Coins</span></h2>
            <button class="bg-white/20 backdrop-blur-md border border-white/30 px-4 py-2 rounded-xl text-sm font-bold flex items-center gap-2">
                <i class="fas fa-plus"></i> Recharge
            </button>
            <i class="fas fa-wallet absolute right-[-20px] bottom-[-20px] text-black/10 text-9xl"></i>
        </div>

        <div class="flex gap-3 overflow-x-auto pb-6 no-scrollbar">
            <button class="category-pill active">Tous</button>
            <button class="category-pill">Streaming</button>
            <button class="category-pill">Boost TikTok</button>
            <button class="category-pill">VCC</button>
        </div>

        <div class="grid grid-cols-2 gap-4">
            <% services.forEach(service => { %>
                <div class="product-card p-4 flex flex-col items-center">
                    <div class="w-20 h-20 mb-4 flex items-center justify-center text-4xl">
                        <%= service.icon || '📦' %>
                    </div>
                    <h3 class="font-bold text-sm text-center mb-1 leading-tight"><%= service.name %></h3>
                    <p class="text-yellow-500 font-bold text-xs mb-4"><%= service.price %> Coins</p>
                    <button class="btn-buy text-[10px] uppercase tracking-wider">Acheter</button>
                </div>
            <% }); %>
        </div>
    </main>

    <nav class="nav-bottom fixed bottom-0 left-0 right-0 h-20 px-8 flex justify-between items-center z-50">
        <a href="/" class="flex flex-col items-center text-yellow-500">
            <i class="fas fa-home text-xl"></i>
            <span class="text-[10px] mt-1 font-bold">Accueil</span>
        </a>
        <a href="/vendre" class="flex flex-col items-center text-slate-500 hover:text-white transition">
            <i class="fas fa-plus-circle text-xl"></i>
            <span class="text-[10px] mt-1 font-bold">Vendre</span>
        </a>
        <a href="/historique" class="flex flex-col items-center text-slate-500">
            <i class="fas fa-history text-xl"></i>
            <span class="text-[10px] mt-1 font-bold">Historique</span>
        </a>
        <a href="/profil" class="flex flex-col items-center text-slate-500">
            <i class="fas fa-user text-xl"></i>
            <span class="text-[10px] mt-1 font-bold">Profil</span>
        </a>
    </nav>

</body>
</html>
