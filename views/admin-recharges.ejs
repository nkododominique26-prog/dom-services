<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8"><title>Admin Recharges - Mr Dom's</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-[#0f111a] text-white p-6 md:p-12">
    <div class="max-w-3xl mx-auto">
        <div class="flex justify-between items-center mb-10">
            <h1 class="text-2xl font-black uppercase">Validation Recharges</h1>
            <a href="/" class="text-gray-500 hover:text-white"><i class="fas fa-times text-2xl"></i></a>
        </div>

        <div class="space-y-4">
            <% pendingRecharges.forEach(recharge => { %>
                <div class="bg-[#161926] p-6 rounded-[2rem] border border-white/5 flex flex-col md:flex-row justify-between items-center gap-6 shadow-xl">
                    <div>
                        <p class="text-[10px] font-bold text-purple-500 uppercase tracking-widest mb-1">Utilisateur</p>
                        <h3 class="text-xl font-black"><%= recharge.userId.username %></h3>
                        <p class="text-2xl font-black text-green-500 mt-2"><%= recharge.amount %> <span class="text-xs">FCFA</span></p>
                        <span class="text-[10px] bg-white/5 px-2 py-1 rounded-md text-gray-400 mt-2 inline-block"><%= recharge.method %></span>
                    </div>

                    <form action="/admin/approve-recharge/<%= recharge._id %>" method="POST">
                        <button type="submit" class="bg-green-600 hover:bg-green-700 px-8 py-4 rounded-2xl font-black transition shadow-lg shadow-green-600/20 active:scale-95 flex items-center gap-3">
                            <i class="fas fa-check-double text-xl"></i> LIBÉRER LES FONDS
                        </button>
                    </form>
                </div>
            <% }) %>

            <% if (pendingRecharges.length === 0) { %>
                <div class="text-center py-20 bg-white/5 rounded-[2rem] border border-dashed border-white/10">
                    <i class="fas fa-coins text-5xl text-gray-700 mb-4"></i>
                    <p class="text-gray-500">Aucune demande de recharge en attente.</p>
                </div>
            <% } %>
        </div>
    </div>
</body>
</html>
