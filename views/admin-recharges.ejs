<body class="bg-[#0f111a] text-white p-6">
    <div class="max-w-2xl mx-auto">
        <h1 class="text-2xl font-black mb-10 uppercase tracking-widest text-purple-500">Vérification des paiements</h1>

        <div class="space-y-6">
            <% pendingRecharges.forEach(r => { %>
                <div class="bg-[#161926] p-6 rounded-[2rem] border border-white/5 shadow-xl">
                    <div class="flex justify-between items-start mb-4">
                        <div>
                            <h3 class="font-bold text-lg"><%= r.userId.username %></h3>
                            <p class="text-green-500 font-black text-2xl"><%= r.amount %> F</p>
                            <span class="text-[10px] text-gray-500 uppercase font-bold"><%= r.method %></span>
                        </div>
                        <a href="<%= r.proofImage %>" target="_blank" class="text-purple-400 text-xs font-bold border-b border-purple-400">Agrandir la preuve</a>
                    </div>

                    <img src="<%= r.proofImage %>" class="w-full h-48 object-cover rounded-2xl mb-6 border border-white/10">

                    <form action="/admin/approve-recharge/<%= r._id %>" method="POST">
                        <button type="submit" class="w-full bg-green-600 hover:bg-green-700 py-4 rounded-2xl font-black transition">
                            LIBÉRER L'ARGENT
                        </button>
                    </form>
                </div>
            <% }) %>

            <% if (pendingRecharges.length === 0) { %>
                <p class="text-center text-gray-600 py-20 italic">Aucune recharge en attente.</p>
            <% } %>
        </div>
    </div>
</body>
