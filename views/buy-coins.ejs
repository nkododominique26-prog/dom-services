<body class="bg-[#0f111a] text-white p-6 font-sans">
    <div class="max-w-md mx-auto bg-[#161926] p-8 rounded-[2.5rem] border border-white/5 shadow-2xl">
        <h1 class="text-2xl font-black mb-6 text-purple-500 text-center uppercase">Recharger</h1>
        
        <div class="space-y-3 mb-8">
            <div class="bg-orange-500/10 p-4 rounded-2xl border border-orange-500/20 flex justify-between items-center">
                <span class="text-orange-500 font-bold">Orange Money</span>
                <span class="font-black tracking-tighter">691163186</span>
            </div>
            <div class="bg-yellow-500/10 p-4 rounded-2xl border border-yellow-500/20 flex justify-between items-center">
                <span class="text-yellow-500 font-bold">MTN MoMo</span>
                <span class="font-black tracking-tighter">681175901</span>
            </div>
        </div>

        <form action="/recharge-request" method="POST" enctype="multipart/form-data" class="space-y-5">
            <input type="number" name="amount" placeholder="Montant transféré (FCFA)" required class="w-full bg-[#0f111a] border border-white/5 p-4 rounded-2xl outline-none focus:border-purple-600 transition">
            
            <select name="method" class="w-full bg-[#0f111a] border border-white/5 p-4 rounded-2xl outline-none">
                <option value="Orange Money">Via Orange Money</option>
                <option value="MTN MoMo">Via MTN MoMo</option>
            </select>

            <div class="p-4 bg-purple-600/5 border border-dashed border-purple-600/20 rounded-2xl">
                <label class="text-[10px] font-bold text-gray-500 uppercase block mb-2">Capture d'écran du succès</label>
                <input type="file" name="proof" accept="image/*" required class="text-xs text-gray-400 file:bg-purple-600 file:text-white file:border-none file:px-4 file:py-2 file:rounded-full file:mr-4">
            </div>

            <button type="submit" class="w-full bg-purple-600 py-4 rounded-2xl font-black shadow-lg shadow-purple-600/20 transition active:scale-95">
                ENVOYER LA PREUVE
            </button>
        </form>
    </div>
</body>
