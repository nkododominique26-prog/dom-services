<body class="bg-[#1a1625] text-white flex items-center justify-center min-h-screen p-6">
    <div class="bg-[#241e35] p-8 rounded-3xl w-full max-w-md shadow-2xl border border-white/5">
        <h1 class="text-2xl font-bold mb-6 text-center text-purple-500">Connexion</h1>
        <form action="/login" method="POST" class="space-y-4">
            <input type="text" name="username" placeholder="Nom d'utilisateur" required class="w-full bg-[#1a1625] border border-gray-700 p-4 rounded-xl">
            <input type="password" name="password" placeholder="Mot de passe" required class="w-full bg-[#1a1625] border border-gray-700 p-4 rounded-xl">
            <button type="submit" class="w-full bg-purple-600 py-4 rounded-xl font-bold">Se connecter</button>
        </form>
        <p class="mt-6 text-center text-gray-400 text-sm">Pas de compte ? <a href="/register" class="text-purple-500 underline">S'inscrire</a></p>
    </div>
</body>
