<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion - Mr Dom's</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body class="bg-[#0f111a] text-white font-sans min-h-screen flex items-center justify-center p-6">

    <div class="w-full max-w-md bg-[#161926] p-8 rounded-[2.5rem] border border-white/5 shadow-2xl">
        <div class="text-center mb-10">
            <div class="inline-flex bg-purple-600 p-4 rounded-2xl mb-4 shadow-lg shadow-purple-600/20">
                <i class="fas fa-user-shield text-2xl"></i>
            </div>
            <h1 class="text-2xl font-bold">Bon retour !</h1>
            <p class="text-gray-500 text-sm mt-2">Connectez-vous à votre espace Mr Dom's</p>
        </div>

        <% if (error) { %>
            <div class="bg-red-500/10 border border-red-500/20 text-red-500 p-4 rounded-xl text-sm mb-6 flex items-center gap-3">
                <i class="fas fa-exclamation-circle"></i> <%= error %>
            </div>
        <% } %>

        <form action="/login" method="POST" class="space-y-5">
            <div>
                <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 ml-1">Nom d'utilisateur</label>
                <input type="text" name="username" required placeholder="Ex: Doms" 
                       class="w-full bg-[#0f111a] border border-white/5 rounded-2xl px-5 py-4 focus:outline-none focus:border-purple-600 transition">
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2 ml-1">Mot de passe</label>
                <input type="password" name="password" required placeholder="••••••••" 
                       class="w-full bg-[#0f111a] border border-white/5 rounded-2xl px-5 py-4 focus:outline-none focus:border-purple-600 transition">
            </div>
            <button type="submit" class="w-full bg-purple-600 hover:bg-purple-700 py-4 rounded-2xl font-bold shadow-lg shadow-purple-600/20 transition active:scale-95">
                Se connecter
            </button>
        </form>

        <p class="text-center mt-8 text-sm text-gray-500">
            Nouveau ici ? <a href="/register" class="text-purple-400 font-bold hover:underline">Créer un compte</a>
        </p>
    </div>

</body>
</html>
