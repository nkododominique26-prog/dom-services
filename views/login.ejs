<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion - Dom's</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#1a1625] text-white flex items-center justify-center min-h-screen">
    <div class="bg-[#241e35] p-8 rounded-3xl w-full max-w-md shadow-2xl border border-white/5">
        <h1 class="text-2xl font-bold mb-6 text-center text-purple-500">Se connecter</h1>

        <% if (error) { %>
            <div class="bg-red-500/20 border border-red-500 text-red-500 p-3 rounded-xl mb-4 text-sm text-center">
                <%= error %>
            </div>
        <% } %>

        <form action="/login" method="POST" class="space-y-4">
            <input type="text" name="username" placeholder="Nom d'utilisateur" required 
                   class="w-full bg-[#1a1625] border border-gray-700 p-4 rounded-xl focus:border-purple-500 outline-none">
            <input type="password" name="password" placeholder="Mot de passe" required 
                   class="w-full bg-[#1a1625] border border-gray-700 p-4 rounded-xl focus:border-purple-500 outline-none">
            <button type="submit" class="w-full bg-purple-600 py-4 rounded-xl font-bold hover:bg-purple-700 transition">
                Connexion
            </button>
        </form>
        <p class="mt-6 text-center text-gray-400 text-sm">Pas encore de compte ? <a href="/register" class="text-purple-500 underline">S'inscrire</a></p>
    </div>
</body>
</html>
