<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Recharger - Dom's Services</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#1a1625] text-white">
    <div class="p-6">
        <h1 class="text-2xl font-bold mb-6 text-purple-500">Choisir un forfait</h1>
        
        <div class="grid grid-cols-1 gap-4">
            <a href="/payer/500" class="bg-[#241e35] p-5 rounded-2xl border border-white/5 flex justify-between items-center">
                <div>
                    <div class="text-lg font-bold text-purple-400">500 Coins</div>
                    <div class="text-sm text-gray-500">500 FCFA</div>
                </div>
                <div class="bg-purple-600 px-4 py-2 rounded-xl text-sm font-bold">Choisir</div>
            </a>

            <a href="/payer/1000" class="bg-[#241e35] p-5 rounded-2xl border border-white/5 flex justify-between items-center">
                <div>
                    <div class="text-lg font-bold text-purple-400">1000 Coins</div>
                    <div class="text-sm text-gray-500">1000 FCFA <span class="text-green-500 text-xs">+50 Bonus</span></div>
                </div>
                <div class="bg-purple-600 px-4 py-2 rounded-xl text-sm font-bold">Choisir</div>
            </a>
        </div>
        <a href="/" class="block text-center mt-8 text-gray-500 text-sm">Annuler et retourner</a>
    </div>
</body>
</html>
